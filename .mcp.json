{
  "mcpServers": {
    "memory-graph": {
      "command": "python3",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp-servers/memory-graph/server.py",
        "--db-path", "${CLAUDE_PLUGIN_ROOT}/../logs"
      ],
      "env": { "SYNTHEX_VECTOR_BACKEND": "chroma" }
    },
    "visualization": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/visualization/server.js"]
    },
    "heavy-compute": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "${CLAUDE_PLUGIN_ROOT}/../agent-output:/workspace/output",
        "-v", "${CLAUDE_PLUGIN_ROOT}/../user-input:/workspace/input:ro",
        "synthex/compute-engine:latest", "mcp-server"
      ]
    }
  }
}
