_CLEANUP_DIRS=()

_cleanup() {
    local exit_code=$?
    echo "[${SCRIPT_NAME}] Cleanup: removing ${#_CLEANUP_DIRS[@]} temporary paths" >&2
    for dir in "${_CLEANUP_DIRS[@]}"; do
        if [[ -d "$dir" ]]; then
            rm -rf "$dir"
        fi
    done
    if [[ $exit_code -ne 0 ]]; then
        echo "[${SCRIPT_NAME}] Exited with code $exit_code" >&2
