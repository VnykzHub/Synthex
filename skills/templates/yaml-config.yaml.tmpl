# Auto-generated by artifact-factory
# Template: yaml-config.yaml.tmpl

# ---------------------------------------------------------------------------
# Project metadata
# ---------------------------------------------------------------------------
project:
  name: {{ name }}
  version: {{ version }}
  description: {{ description }}

  author:
    name: {{ author_name }}
    email: {{ author_email }}

  repository: {{ repository_url }}
  license: {{ license }}

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
dependencies:
  python: ">=3.12"

  packages:
    {% for dep in dependencies %}
    - name: {{ dep.name }}
      version: "{{ dep.version }}"
      source: "{{ dep.source | default('pypi') }}"
    {% endfor %}

  optional:
    {% for dep in optional_dependencies %}
    - name: {{ dep.name }}
      version: "{{ dep.version }}"
      extras: {{ dep.extras | default([]) }}
    {% endfor %}

# ---------------------------------------------------------------------------
# Runtime settings
# ---------------------------------------------------------------------------
settings:
  debug: {{ debug | default(false) }}
  log_level: {{ log_level | default("INFO") }}
  max_retries: {{ max_retries | default(3) }}
  timeout_seconds: {{ timeout_seconds | default(60) }}

  paths:
    input_dir: {{ input_dir | default("user-input") }}
    output_dir: {{ output_dir | default("agent-output") }}
    knowledge_base: {{ knowledge_base | default("knowledgebase") }}

  plugins:
    enabled: {{ plugins_enabled | default([]) }}

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
features:
  {% for flag in feature_flags %}
  {{ flag.name }}: {{ flag.enabled | default(false) }}
  {% endfor %}
